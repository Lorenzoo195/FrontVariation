---
// src/components/ProjectCard.astro
const { title, description, tech, link } = Astro.props;
---
<div class="flex flex-col h-full bg-white/5 border border-white/10 p-6 rounded-2xl backdrop-blur-sm hover:-translate-y-1 hover:bg-white/10 transition-all duration-300 cursor-pointer group">
	<h3 class="text-xl font-bold mb-2 text-white group-hover:text-blue-400 transition-colors">{title}</h3>
	<p class="text-zinc-400 text-sm mb-4 line-clamp-2">{description}</p>
	<div class="flex flex-wrap gap-2 mb-4">
		{tech.map((item: any) => (
			<span class="px-3 py-1 bg-white/10 rounded-full text-xs text-zinc-300 border border-white/5">{item}</span>
		))}
	</div>
	<div class="mt-auto pt-4 border-t border-white/5">
		<a href={link} class="inline-flex items-center gap-2 text-sm text-zinc-300 hover:text-white transition-colors">
			Ver proyecto <span class="group-hover:translate-x-1 transition-transform">→</span>
		</a>
	</div>
</div>
