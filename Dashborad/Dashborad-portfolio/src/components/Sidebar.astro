---
// src/components/Sidebar.astro
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isProjects = pathname.startsWith('/proyectos');
---
<aside class="group w-20 hover:w-64 h-full bg-zinc-950 border-r border-white/10 flex flex-col py-6 transition-all duration-300 ease-out relative z-50 overflow-hidden">
	
	<!-- Logo Instagram Style -->
	<a href="/" class="flex items-center mb-10 px-6 w-full cursor-pointer">
		<div class="min-w-10 h-10 flex items-center justify-center">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-white">
				<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
				<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
				<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
			</svg>
		</div>
		<span class="ml-4 text-xl font-bold tracking-tight text-white opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap">
			Portfolio
		</span>
	</a>

	<!-- Menú de Iconos -->
	<nav class="flex flex-col gap-2 w-full px-3">
		
		<!-- Inicio -->
		<a href="/" class={`flex items-center w-full rounded-xl transition-all duration-200 hover:bg-white/5 py-3 ${isHome ? 'font-bold' : ''}`}>
			<div class="min-w-14 flex items-center justify-center">
				<svg class={`w-7 h-7 ${isHome ? 'text-white' : 'text-zinc-400'}`} fill={isHome ? "currentColor" : "none"} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
				</svg>
			</div>
			<span class={`ml-1 text-base opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap ${isHome ? 'text-white font-bold' : 'text-zinc-200'}`}>
				Inicio
			</span>
		</a>

		<!-- Proyectos (Nuestra sección especial) -->
		<a href="/proyectos" class={`flex items-center w-full rounded-xl transition-all duration-200 hover:bg-white/5 py-3 ${isProjects ? 'font-bold' : ''}`}>
			<div class="min-w-14 flex items-center justify-center">
				<svg class={`w-7 h-7 ${isProjects ? 'text-white' : 'text-zinc-400'}`} fill={isProjects ? "currentColor" : "none"} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
				</svg>
			</div>
			<span class={`ml-1 text-base opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap ${isProjects ? 'text-white font-bold' : 'text-zinc-200'}`}>
				Proyectos
			</span>
		</a>

		<!-- Mensajes con Notificación -->
		<a href="#" class="flex items-center w-full rounded-xl transition-all duration-200 hover:bg-white/5 py-3 relative">
			<div class="min-w-14 flex items-center justify-center relative">
				<svg class="w-7 h-7 text-zinc-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
				</svg>
				<div class="absolute top-0 right-3 w-4 h-4 bg-red-600 text-[10px] font-bold text-white flex items-center justify-center rounded-full border-2 border-zinc-950 translate-x-1 -translate-y-1">
					1
				</div>
			</div>
			<span class="ml-1 text-base text-zinc-200 opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap">
				Mensajes
			</span>
		</a>

		<!-- Notificaciones -->
		<a href="#" class="flex items-center w-full rounded-xl transition-all duration-200 hover:bg-white/5 py-3">
			<div class="min-w-14 flex items-center justify-center">
				<svg class="w-7 h-7 text-zinc-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
				</svg>
			</div>
			<span class="ml-1 text-base text-zinc-200 opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap">
				Notificaciones
			</span>
		</a>

		<!-- Crear -->
		<a href="#" class="flex items-center w-full rounded-xl transition-all duration-200 hover:bg-white/5 py-3">
			<div class="min-w-14 flex items-center justify-center">
				<svg class="w-7 h-7 text-zinc-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
				</svg>
			</div>
			<span class="ml-1 text-base text-zinc-200 opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap">
				Crear
			</span >
		</a>

	</nav>

	<!-- Footer Sidebar -->
	<div class="mt-auto w-full px-3">
		<a href="#" class="flex items-center w-full rounded-xl transition-all duration-200 hover:bg-white/5 py-3">
			<div class="min-w-14 flex items-center justify-center">
				<svg class="w-7 h-7 text-zinc-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
				</svg>
			</div>
			<span class="ml-1 text-base text-zinc-200 opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap">
				Más opciones
			</span>
		</a>
	</div>
</aside>
