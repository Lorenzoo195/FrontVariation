---
// src/components/ProfileHeader.astro
---
<header class="flex flex-col md:flex-row items-center md:items-start gap-10 mb-12 animate-fade-in-up">
	<!-- Avatar con gradiente circular estilo Instagram -->
	<div class="relative">
		<div class="w-36 h-36 rounded-full bg-linear-to-tr from-yellow-400 via-red-500 to-purple-600 p-[3px] shadow-2xl">
			<div class="w-full h-full rounded-full bg-zinc-900 p-1">
				<img 
					src="https://api.dicebear.com/7.x/notionists/svg?seed=Felix&backgroundColor=transparent" 
					alt="Avatar" 
					class="w-full h-full object-cover rounded-full"
				/>
			</div>
		</div>
		<!-- Indicador de "On-line" -->
		<div class="absolute bottom-2 right-2 w-6 h-6 bg-green-500 border-4 border-zinc-950 rounded-full"></div>
	</div>
	
	<!-- Información del Perfil -->
	<div class="flex-1">
		<div class="flex flex-wrap items-center gap-4 mb-6">
			<h2 class="text-2xl font-light">lorenzolacarte7</h2>
			<div class="flex gap-2">
				<button class="px-5 py-1.5 bg-zinc-800 hover:bg-zinc-700 text-white text-sm font-semibold rounded-lg transition-colors border border-white/5">
					Editar perfil
				</button>
				<button class="px-5 py-1.5 bg-zinc-800 hover:bg-zinc-700 text-white text-sm font-semibold rounded-lg transition-colors border border-white/5">
					Ver archivo
				</button>
			</div>
			<!-- Icono de configuración / Opciones -->
			<button class="text-zinc-200 hover:text-white transition-colors">
				<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
					<path d="M18.944 11.112C18.507 7.314 ..."></path>
					<circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"></circle>
					<path stroke="currentColor" stroke-width="2" d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"></path>
                    <path fill="currentColor" d="M12 15.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7zm0-5.5a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
				</svg>
			</button>
		</div>

		<!-- Estadísticas -->
		<div class="flex gap-8 mb-6">
			<span class="text-base font-light text-zinc-300"><strong class="font-semibold text-white">8</strong> publicaciones</span>
			<span class="text-base font-light text-zinc-300"><strong class="font-semibold text-white">412</strong> seguidores</span>
			<span class="text-base font-light text-zinc-300"><strong class="font-semibold text-white">366</strong> seguidos</span>
		</div>

		<!-- Bio -->
		<div>
			<h3 class="font-semibold text-base mb-1 text-white">Lorenzo Lacarte</h3>
			<p class="text-zinc-400 text-sm leading-snug max-w-sm">
				📍 Zaragoza<br/>
				Desarrollador Frontend | Aprendiendo desarrollo web escalable.<br/>
				Explorando el diseño creativo con Astro y Tailwind.
			</p>
		</div>
	</div>
</header>
