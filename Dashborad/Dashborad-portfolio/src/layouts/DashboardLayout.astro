---
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';
// src/layouts/DashboardLayout.astro
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Mi Portfolio Dashboard</title>
	</head>
	<body class="bg-zinc-950 text-white h-screen flex overflow-hidden font-sans">
		
		<Sidebar />

		<main class="flex-1 h-full overflow-y-auto p-8 relative">
			<div class="absolute top-0 left-0 w-[500px] h-[500px] bg-purple-500/20 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
			<div class="absolute -bottom-32 -right-32 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
			
			<slot />
		</main>

	</body>
</html>